{
  // See https://go.microsoft.com/fwlink/?LinkId=733558
  // for the documentation about the tasks.json format
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build_debug",
      "type": "shell",
      "command": "make",
      "args": ["compile"],
      "problemMatcher": "$gcc"
    },
    {
      "label": "flash_hex",
      "type": "shell",
      "command": "st-flash",
      "args": [
        "--format", "ihex", "write", 
        "@LAUNCH_HEX_FILE@"
      ],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "build_and_flash",
      "dependsOn": ["build_debug", "flash_hex"],
      "problemMatcher": []
    }
  ]
}
